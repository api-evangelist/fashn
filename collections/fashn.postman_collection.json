          "name": "Retrieve prediction status and output",
          "request": {
            "name": "Retrieve prediction status and output",
            "description": {
              "content": "Returns the current state of a prediction. CDN output URLs are valid for 72 hours; base64 outputs are valid for 60 minutes. Rate limit: 50 requests per 10 seconds.",
              "type": "text/plain"
            },
            "url": {
              "path": [
                "status",
                ":id"
              ],
              "host": [
                "{{baseUrl}}"
              ],
              "query": [],
              "variable": [
                {
                  "disabled": false,
                  "type": "any",
                  "value": "<uuid>",
                  "key": "id",
                  "description": "(Required) Prediction identifier returned from /run."
