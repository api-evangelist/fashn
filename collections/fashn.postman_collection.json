  "info": {
    "_postman_id": "a63a938b-ff93-4fc8-80f3-3fc9a5a57693",
    "name": "FASHN AI API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": {
      "content": "FASHN AI is a generative-image platform tailored for fashion. The public API exposes an asynchronous prediction workflow: clients submit a job against a named model with model-specific inputs, then poll a status endpoint until the prediction completes. Models include Try-On Max, Product to Model, Face to Model, Model Create, Model Swap, Edit, Reframe, Image to Video, and Background Remove.\n\nContact Support:\n Name: FASHN AI",
      "type": "text/plain"
    }
  }
